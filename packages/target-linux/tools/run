#!/bin/sh
set -eu

program="${2:-.}"
tool_dir="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"
arch=""
runner="host"
app_args=""
after_dash=0
out="dist-linux-qemu"
qemu_image="${AILANG_LINUX_QEMU_IMAGE:-}"
qemu_seed="${AILANG_LINUX_QEMU_SEED:-}"
qemu_efi_code="${AILANG_LINUX_QEMU_EFI_CODE:-}"
qemu_efi_vars="${AILANG_LINUX_QEMU_EFI_VARS:-}"
qemu_efi_vars_template="${AILANG_LINUX_QEMU_EFI_VARS_TEMPLATE:-}"
qemu_user="${AILANG_LINUX_QEMU_USER:-ailang}"
qemu_ssh_port="${AILANG_LINUX_QEMU_SSH_PORT:-2222}"
qemu_ssh_key="${AILANG_LINUX_QEMU_SSH_KEY:-}"
qemu_display="${AILANG_LINUX_QEMU_DISPLAY:-cocoa}"
qemu_memory="${AILANG_LINUX_QEMU_MEMORY:-4096}"
qemu_smp="${AILANG_LINUX_QEMU_SMP:-4}"
qemu_accel="${AILANG_LINUX_QEMU_ACCEL:-hvf}"
qemu_cpu="${AILANG_LINUX_QEMU_CPU:-host}"
qemu_serial_log="${AILANG_LINUX_QEMU_SERIAL_LOG:-}"
qemu_extra_args=""
guest_display="${AILANG_LINUX_QEMU_GUEST_DISPLAY:-:0}"
display_backend="${AILANG_LINUX_DISPLAY_BACKEND:-auto}"
run_tool=""
app_aibc1=""
aivectra_runtime=""
aivectra_runtime_kind=""
qemu_cache_schema="ailang.target-linux.qemu.v3"

host_default_arch() {
  case "$(uname -m 2>/dev/null || true)" in
    arm64|aarch64) printf '%s\n' "aarch64" ;;
    x86_64|amd64) printf '%s\n' "x86_64" ;;
    *) uname -m ;;
  esac
}

project_manifest_path() {
  if [ -d "$program" ] && [ -f "$program/project.aiproj" ]; then
    printf '%s\n' "$program/project.aiproj"
    return 0
  fi
  if [ -f "$program" ] && [ "$(basename "$program")" = "project.aiproj" ]; then
    printf '%s\n' "$program"
    return 0
  fi
  return 1
}

project_dir_path() {
  manifest="$(project_manifest_path)" || return 1
  dirname "$manifest"
}

project_run_tool() {
  manifest="$(project_manifest_path)" || return 1
  sed -n 's/.*runTool="\([^"]*\)".*/\1/p' "$manifest" | head -n 1
}

runtime_is_framebuffer() {
  candidate="$1"
  if command -v strings >/dev/null 2>&1 && strings "$candidate" 2>/dev/null | grep -Fq "/dev/fb0"; then
    return 0
  fi
  return 1
}

resolve_aivectra_x11_runtime() {
  for candidate in \
    "${AILANG_LINUX_AIVECTRA_X11_BIN:-}" \
    "${AILANG_SDK_ROOT:-}/runtimes/linux-arm64/aivectra-x11" \
    "${HOME:-}/.ailang/local/runtimes/linux-arm64/aivectra-x11" \
    "${HOME:-}/.ailang/current/runtimes/linux-arm64/aivectra-x11" \
    "${HOME:-}/.ailang/toolchains/0.0.1-beta.22/runtimes/linux-arm64/aivectra-x11" \
    "${AILANG_LINUX_AIVECTRA_BIN:-}" \
    "${AILANG_SDK_ROOT:-}/runtimes/linux-arm64/aivectra" \
    "${HOME:-}/.ailang/local/runtimes/linux-arm64/aivectra" \
    "${HOME:-}/.ailang/current/runtimes/linux-arm64/aivectra" \
    "${HOME:-}/.ailang/toolchains/0.0.1-beta.22/runtimes/linux-arm64/aivectra"
  do
    if [ -n "$candidate" ] && [ -x "$candidate" ] && ! runtime_is_framebuffer "$candidate"; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

resolve_aivectra_framebuffer_runtime() {
  for candidate in \
    "${AILANG_LINUX_AIVECTRA_FRAMEBUFFER_BIN:-}" \
    "${AILANG_SDK_ROOT:-}/runtimes/linux-arm64/aivectra-framebuffer" \
    "${HOME:-}/.ailang/local/runtimes/linux-arm64/aivectra-framebuffer" \
    "${HOME:-}/.ailang/current/runtimes/linux-arm64/aivectra-framebuffer" \
    "${HOME:-}/.ailang/toolchains/0.0.1-beta.22/runtimes/linux-arm64/aivectra-framebuffer" \
    "${AILANG_LINUX_AIVECTRA_BIN:-}" \
    "${AILANG_SDK_ROOT:-}/runtimes/linux-arm64/aivectra" \
    "${HOME:-}/.ailang/local/runtimes/linux-arm64/aivectra" \
    "${HOME:-}/.ailang/current/runtimes/linux-arm64/aivectra" \
    "${HOME:-}/.ailang/toolchains/0.0.1-beta.22/runtimes/linux-arm64/aivectra"
  do
    if [ -n "$candidate" ] && [ -x "$candidate" ] && runtime_is_framebuffer "$candidate"; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

repair_qemu_guest_display() {
  ssh $ssh_opts "$qemu_user@127.0.0.1" "sudo sh -eu <<'EOS'
mkdir -p /etc/systemd/resolved.conf.d
cat > /etc/systemd/resolved.conf.d/ailang-qemu.conf <<'EOF'
[Resolve]
DNS=10.0.2.3 1.1.1.1 8.8.8.8
FallbackDNS=1.1.1.1 8.8.8.8
EOF
systemctl restart systemd-resolved 2>/dev/null || true
iface=\$(ip route | awk '/default/ {print \$5; exit}')
if [ -n \"\$iface\" ] && command -v resolvectl >/dev/null 2>&1; then
  resolvectl dns \"\$iface\" 10.0.2.3 1.1.1.1 8.8.8.8 2>/dev/null || true
fi
systemctl disable --now systemd-networkd-wait-online.service 2>/dev/null || true
systemctl mask systemd-networkd-wait-online.service 2>/dev/null || true
usermod -a -G input,video ailang 2>/dev/null || true
DEBIAN_FRONTEND=noninteractive apt-get update -o Acquire::Retries=3
DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
  ca-certificates \
  openssh-server \
  xserver-xorg-core \
  xserver-xorg-input-libinput \
  xinit \
  openbox \
  dbus-x11 \
  x11-xserver-utils \
  x11-utils \
  xterm
cat > /etc/systemd/system/ailang-x11.service <<'EOF'
[Unit]
Description=AiLang target-linux QEMU X11 session
After=systemd-user-sessions.service

[Service]
User=ailang
Environment=HOME=/home/ailang
Environment=DISPLAY=:0
WorkingDirectory=/home/ailang
StandardInput=tty
TTYPath=/dev/tty1
TTYReset=yes
TTYVHangup=yes
ExecStart=/usr/bin/xinit /usr/bin/openbox-session -- /usr/bin/Xorg :0 vt1 -nolisten tcp -noreset
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
EOF
systemctl daemon-reload
systemctl enable --now ssh
systemctl enable --now ailang-x11.service
systemctl restart ailang-x11.service
EOS"
}

append_app_arg() {
  app_args="${app_args}${app_args:+
}$1"
}

apply_target_option() {
  value="$1"
  name="${value%%=*}"
  option_value="${value#*=}"
  if [ "$name" = "$value" ]; then
    echo "Err#err1(code=TARGET001 message=\"Invalid Linux target option. Expected name=value: $value\" nodeId=target-linux)" >&2
    exit 2
  fi
  case "$name" in
    arch) arch="$option_value" ;;
    runner) runner="$option_value" ;;
    qemu-image) qemu_image="$option_value" ;;
    qemu-seed) qemu_seed="$option_value" ;;
    qemu-efi-code) qemu_efi_code="$option_value" ;;
    qemu-efi-vars) qemu_efi_vars="$option_value" ;;
    qemu-efi-vars-template) qemu_efi_vars_template="$option_value" ;;
    qemu-user) qemu_user="$option_value" ;;
    qemu-ssh-port) qemu_ssh_port="$option_value" ;;
    qemu-ssh-key) qemu_ssh_key="$option_value" ;;
    qemu-display) qemu_display="$option_value" ;;
    qemu-memory) qemu_memory="$option_value" ;;
    qemu-smp) qemu_smp="$option_value" ;;
    qemu-accel) qemu_accel="$option_value" ;;
    qemu-cpu) qemu_cpu="$option_value" ;;
    qemu-guest-display) guest_display="$option_value" ;;
    qemu-serial-log) qemu_serial_log="$option_value" ;;
    display-backend) display_backend="$option_value" ;;
    *)
      echo "Err#err1(code=TARGET001 message=\"Unsupported Linux target option: $name\" nodeId=target-linux)" >&2
      exit 2
      ;;
  esac
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --) after_dash=1; shift; continue ;;
  esac
  if [ "$after_dash" -eq 1 ]; then
    qemu_extra_args="${qemu_extra_args}${qemu_extra_args:+
}$1"
    shift
    continue
  fi
  case "$1" in
    --out) out="${2:-dist-linux-qemu}"; shift 2 ;;
    --target-option)
      apply_target_option "${2:-}"
      shift 2
      ;;
    --target-option=*)
      apply_target_option "${1#--target-option=}"
      shift
      ;;
    *) shift ;;
  esac
done

case "${arch:-$(host_default_arch)}" in
  arm64|aarch64) arch="aarch64"; rid="linux-arm64" ;;
  x64|x86_64|amd64) arch="x86_64"; rid="linux-x64" ;;
  *) echo 'Err#err1(code=TARGET001 message="Unsupported Linux target arch." nodeId=target-linux)' >&2; exit 2 ;;
esac
case "$display_backend" in
  auto|x11|framebuffer) ;;
  *) echo 'Err#err1(code=TARGET001 message="Unsupported Linux display backend. Expected auto, x11, or framebuffer." nodeId=target-linux)' >&2; exit 2 ;;
esac

AILANG_BIN="${AILANG_BIN:-ailang}"
export AILANG_DISABLE_PACKAGE_TARGET_DISPATCH=1

run_tool="$(project_run_tool || true)"

if [ "$runner" != "qemu" ]; then
  if [ "$(uname -s)" != "Linux" ]; then
    echo 'Err#err1(code=TARGET001 message="target-linux run requires a Linux host; use --target-option runner=qemu for a prepared Linux QEMU guest, or use publish for cross-target output." nodeId=target-linux)' >&2
    exit 2
  fi
  export AILANG_DISABLE_RUN_TOOL_DISPATCH=1
  if [ -n "$app_args" ]; then
    # shellcheck disable=SC2086
    exec "$AILANG_BIN" run "$program" --target "$rid" -- $app_args
  fi
  exec "$AILANG_BIN" run "$program" --target "$rid"
fi

if [ "$arch" != "aarch64" ]; then
  echo 'Err#err1(code=TARGET001 message="target-linux QEMU runner currently supports aarch64 guests only." nodeId=target-linux)' >&2
  exit 2
fi
if ! command -v qemu-system-aarch64 >/dev/null 2>&1; then
  echo 'Err#err1(code=TARGET001 message="qemu-system-aarch64 is required for target-linux runner=qemu." nodeId=target-linux)' >&2
  exit 2
fi
if ! command -v ssh >/dev/null 2>&1 || ! command -v scp >/dev/null 2>&1; then
  echo 'Err#err1(code=TARGET001 message="ssh and scp are required for target-linux runner=qemu." nodeId=target-linux)' >&2
  exit 2
fi
if [ -z "$qemu_image" ]; then
  qemu_cache_dir="${AILANG_LINUX_QEMU_CACHE_DIR:-${HOME:-.}/.ailang/cache/target-linux/qemu/$arch/ubuntu-noble}"
  qemu_image="$qemu_cache_dir/linux-arm64.qcow2"
  qemu_seed="$qemu_cache_dir/seed.iso"
  qemu_manifest="$qemu_cache_dir/manifest.toml"
  if { [ -f "$qemu_manifest" ] && ! grep -q "schema = \"$qemu_cache_schema\"" "$qemu_manifest"; } || { [ ! -f "$qemu_manifest" ] && [ -f "$qemu_image" ]; }; then
    echo "target-linux qemu: stale guest cache detected; rebuilding mutable guest image" >&2
    rm -f "$qemu_image" "$qemu_seed" "$qemu_manifest"
    rm -rf "$qemu_cache_dir/seed"
  fi
  if [ ! -f "$qemu_image" ] || [ ! -f "$qemu_seed" ]; then
    "$tool_dir/prepare-qemu" --arch "$arch" --out "$qemu_cache_dir" >/dev/null
  fi
fi
if [ -z "$qemu_image" ] || [ ! -f "$qemu_image" ]; then
  echo 'Err#err1(code=TARGET001 message="target-linux runner=qemu could not prepare or find an ARM64 Linux guest image." nodeId=target-linux)' >&2
  exit 2
fi
if [ -z "$qemu_seed" ]; then
  qemu_seed="$(dirname "$qemu_image")/seed.iso"
fi
if [ -z "$qemu_ssh_key" ] && [ -f "$(dirname "$qemu_image")/ailang_qemu_ed25519" ]; then
  qemu_ssh_key="$(dirname "$qemu_image")/ailang_qemu_ed25519"
fi
if [ -z "$qemu_efi_code" ]; then
  for candidate in \
    /opt/homebrew/share/qemu/edk2-aarch64-code.fd \
    /usr/local/share/qemu/edk2-aarch64-code.fd
  do
    if [ -f "$candidate" ]; then
      qemu_efi_code="$candidate"
      break
    fi
  done
fi
if [ -z "$qemu_efi_code" ] || [ ! -f "$qemu_efi_code" ]; then
  echo 'Err#err1(code=TARGET001 message="target-linux runner=qemu requires an ARM64 EFI code file. Set --target-option qemu-efi-code=<path>." nodeId=target-linux)' >&2
  exit 2
fi
if [ -z "$qemu_efi_vars_template" ]; then
  for candidate in \
    /opt/homebrew/share/qemu/edk2-arm-vars.fd \
    /usr/local/share/qemu/edk2-arm-vars.fd
  do
    if [ -f "$candidate" ]; then
      qemu_efi_vars_template="$candidate"
      break
    fi
  done
fi
if [ -z "$qemu_efi_vars" ]; then
  qemu_state_dir="${AILANG_LINUX_QEMU_STATE_DIR:-$PWD/.ailang/qemu-linux}"
  mkdir -p "$qemu_state_dir"
  qemu_efi_vars="$qemu_state_dir/efi-vars.fd"
fi
if [ ! -f "$qemu_efi_vars" ]; then
  if [ -z "$qemu_efi_vars_template" ] || [ ! -f "$qemu_efi_vars_template" ]; then
    echo 'Err#err1(code=TARGET001 message="target-linux runner=qemu requires EFI vars or an EFI vars template." nodeId=target-linux)' >&2
    exit 2
  fi
  cp "$qemu_efi_vars_template" "$qemu_efi_vars"
fi

if [ "$run_tool" = "aivectra" ]; then
  project_dir="$(project_dir_path)"
  "$AILANG_BIN" build "$project_dir" >/dev/null
  app_aibc1="$project_dir/app.aibc1"
  if [ ! -f "$app_aibc1" ]; then
    echo 'Err#err1(code=TARGET001 message="target-linux QEMU AiVectra build did not produce app.aibc1." nodeId=target-linux)' >&2
    exit 2
  fi
  case "$display_backend" in
    x11)
      aivectra_runtime="$(resolve_aivectra_x11_runtime || true)"
      aivectra_runtime_kind="x11"
      ;;
    framebuffer)
      aivectra_runtime="$(resolve_aivectra_framebuffer_runtime || true)"
      aivectra_runtime_kind="framebuffer"
      ;;
    auto)
      aivectra_runtime="$(resolve_aivectra_x11_runtime || true)"
      if [ -n "$aivectra_runtime" ]; then
        aivectra_runtime_kind="x11"
      else
        aivectra_runtime="$(resolve_aivectra_framebuffer_runtime || true)"
        aivectra_runtime_kind="framebuffer"
      fi
      ;;
  esac
  if [ -z "$aivectra_runtime" ]; then
    if [ "$display_backend" = "x11" ]; then
      echo 'Err#err1(code=TARGET001 message="target-linux QEMU AiVectra X11 run requires a Linux ARM64 aivectra-x11 runtime in the SDK. The installed runtime appears to be framebuffer-only or missing." nodeId=target-linux)' >&2
    else
      echo 'Err#err1(code=TARGET001 message="target-linux QEMU AiVectra run requires a Linux ARM64 aivectra runtime in the SDK." nodeId=target-linux)' >&2
    fi
    exit 2
  fi
  echo "target-linux qemu: selected AiVectra backend $aivectra_runtime_kind" >&2
  app_name="aivectra"
else
  "$AILANG_BIN" publish "$program" --target "$rid" --out "$out" >/dev/null
  app_name="$(basename "$(find "$out" -maxdepth 1 -type f -perm -111 ! -name app.aibc1 | head -n 1)")"
  if [ -z "$app_name" ]; then
    echo 'Err#err1(code=TARGET001 message="target-linux QEMU publish did not produce an executable." nodeId=target-linux)' >&2
    exit 2
  fi
fi

ssh_opts="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR -o ConnectTimeout=3 -p $qemu_ssh_port"
scp_opts="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR -o ConnectTimeout=3 -P $qemu_ssh_port"
if [ -n "$qemu_ssh_key" ]; then
  ssh_opts="$ssh_opts -i $qemu_ssh_key"
  scp_opts="$scp_opts -i $qemu_ssh_key"
fi

if ! ssh $ssh_opts "$qemu_user@127.0.0.1" true >/dev/null 2>&1; then
  echo "target-linux qemu: starting aarch64 guest on ssh port $qemu_ssh_port" >&2
  qemu_args_file="${qemu_state_dir:-$PWD/.ailang/qemu-linux}/qemu.args"
  mkdir -p "$(dirname "$qemu_args_file")"
  if [ -z "$qemu_serial_log" ]; then
    qemu_serial_log="$(dirname "$qemu_args_file")/serial.log"
  fi
  rm -f "$qemu_serial_log"
  {
    printf '%s\n' qemu-system-aarch64
    printf '%s\n' -machine "virt,accel=$qemu_accel"
    printf '%s\n' -cpu "$qemu_cpu"
    printf '%s\n' -smp "$qemu_smp"
    printf '%s\n' -m "$qemu_memory"
    printf '%s\n' -display "$qemu_display"
    printf '%s\n' -device virtio-gpu-pci
    printf '%s\n' -device virtio-rng-pci
    printf '%s\n' -device qemu-xhci
    printf '%s\n' -device usb-kbd
    printf '%s\n' -device usb-tablet
    printf '%s\n' -serial "file:$qemu_serial_log"
    printf '%s\n' -drive "if=pflash,format=raw,readonly=on,file=$qemu_efi_code"
    printf '%s\n' -drive "if=pflash,format=raw,file=$qemu_efi_vars"
    printf '%s\n' -drive "if=virtio,format=qcow2,file=$qemu_image"
    if [ -f "$qemu_seed" ]; then
      printf '%s\n' -drive "if=virtio,format=raw,readonly=on,file=$qemu_seed"
    fi
    printf '%s\n' -netdev "user,id=net0,hostfwd=tcp::$qemu_ssh_port-:22"
    printf '%s\n' -device virtio-net-pci,netdev=net0
  } > "$qemu_args_file"
  qemu_daemonize_args="-daemonize"
  if [ "$qemu_display" = "cocoa" ]; then
    qemu_daemonize_args=""
  fi
  if [ -f "$qemu_seed" ]; then
    # shellcheck disable=SC2086
    qemu-system-aarch64 \
      -machine "virt,accel=$qemu_accel" \
      -cpu "$qemu_cpu" \
      -smp "$qemu_smp" \
      -m "$qemu_memory" \
      $qemu_daemonize_args \
      -display "$qemu_display" \
      -device virtio-gpu-pci \
      -device virtio-rng-pci \
      -device qemu-xhci \
      -device usb-kbd \
      -device usb-tablet \
      -serial "file:$qemu_serial_log" \
      -drive "if=pflash,format=raw,readonly=on,file=$qemu_efi_code" \
      -drive "if=pflash,format=raw,file=$qemu_efi_vars" \
      -drive "if=virtio,format=qcow2,file=$qemu_image" \
      -drive "if=virtio,format=raw,readonly=on,file=$qemu_seed" \
      -netdev "user,id=net0,hostfwd=tcp::$qemu_ssh_port-:22" \
      -device virtio-net-pci,netdev=net0 &
  else
    # shellcheck disable=SC2086
    qemu-system-aarch64 \
      -machine "virt,accel=$qemu_accel" \
      -cpu "$qemu_cpu" \
      -smp "$qemu_smp" \
      -m "$qemu_memory" \
      $qemu_daemonize_args \
      -display "$qemu_display" \
      -device virtio-gpu-pci \
      -device virtio-rng-pci \
      -device qemu-xhci \
      -device usb-kbd \
      -device usb-tablet \
      -serial "file:$qemu_serial_log" \
      -drive "if=pflash,format=raw,readonly=on,file=$qemu_efi_code" \
      -drive "if=pflash,format=raw,file=$qemu_efi_vars" \
      -drive "if=virtio,format=qcow2,file=$qemu_image" \
      -netdev "user,id=net0,hostfwd=tcp::$qemu_ssh_port-:22" \
      -device virtio-net-pci,netdev=net0 &
  fi
  sleep 2
fi

ready=0
waited=0
echo "target-linux qemu: waiting for SSH on 127.0.0.1:$qemu_ssh_port" >&2
for _ in $(seq 1 600); do
  if ssh $ssh_opts "$qemu_user@127.0.0.1" true >/dev/null 2>&1; then
    ready=1
    break
  fi
  waited=$((waited + 1))
  if [ $((waited % 15)) -eq 0 ]; then
    echo "target-linux qemu: still waiting for SSH (${waited}s); serial log: $qemu_serial_log" >&2
  fi
  sleep 1
done
if [ "$ready" != "1" ]; then
  echo 'Err#err1(code=TARGET001 message="target-linux QEMU guest did not become reachable over SSH." nodeId=target-linux)' >&2
  exit 2
fi

if [ "$run_tool" != "aivectra" ] || [ "$aivectra_runtime_kind" = "x11" ]; then
  x_ready=0
  waited=0
  echo "target-linux qemu: waiting for X11 on DISPLAY=$guest_display" >&2
  for _ in $(seq 1 60); do
    if ssh $ssh_opts "$qemu_user@127.0.0.1" "test -S /tmp/.X11-unix/X0" >/dev/null 2>&1; then
      x_ready=1
      break
    fi
    waited=$((waited + 1))
    if [ $((waited % 15)) -eq 0 ]; then
      echo "target-linux qemu: still waiting for X11 (${waited}s)" >&2
    fi
    sleep 1
  done
  if [ "$x_ready" != "1" ]; then
    echo "target-linux qemu: X11 is not ready; repairing guest display packages" >&2
    repair_qemu_guest_display
    waited=0
    for _ in $(seq 1 180); do
      if ssh $ssh_opts "$qemu_user@127.0.0.1" "test -S /tmp/.X11-unix/X0" >/dev/null 2>&1; then
        x_ready=1
        break
      fi
      waited=$((waited + 1))
      if [ $((waited % 15)) -eq 0 ]; then
        echo "target-linux qemu: still waiting for repaired X11 (${waited}s)" >&2
      fi
      sleep 1
    done
  fi
  if [ "$x_ready" != "1" ]; then
    echo 'Err#err1(code=TARGET001 message="target-linux QEMU guest became reachable, but X11 did not become ready on DISPLAY=:0." nodeId=target-linux)' >&2
    exit 2
  fi
fi

remote_dir="/tmp/ailang-target-linux-$app_name"
ssh $ssh_opts "$qemu_user@127.0.0.1" "rm -rf '$remote_dir' && mkdir -p '$remote_dir'"
if [ "$run_tool" = "aivectra" ]; then
  scp $scp_opts "$app_aibc1" "$qemu_user@127.0.0.1:$remote_dir/app.aibc1" >/dev/null
  scp $scp_opts "$aivectra_runtime" "$qemu_user@127.0.0.1:$remote_dir/aivectra" >/dev/null
  if [ "$aivectra_runtime_kind" = "framebuffer" ]; then
    ssh $ssh_opts "$qemu_user@127.0.0.1" "sudo systemctl stop ailang-x11.service 2>/dev/null || true; sudo chvt 1 2>/dev/null || true; chmod +x '$remote_dir/aivectra' && '$remote_dir/aivectra' '$remote_dir/app.aibc1'"
  else
    ssh $ssh_opts "$qemu_user@127.0.0.1" "chmod +x '$remote_dir/aivectra' && DISPLAY='$guest_display' '$remote_dir/aivectra' '$remote_dir/app.aibc1'"
  fi
else
  scp $scp_opts -r "$out/." "$qemu_user@127.0.0.1:$remote_dir/" >/dev/null
  ssh $ssh_opts "$qemu_user@127.0.0.1" "chmod +x '$remote_dir/$app_name' && DISPLAY='$guest_display' '$remote_dir/$app_name'"
fi
